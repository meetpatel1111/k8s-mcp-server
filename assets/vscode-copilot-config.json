{
  "//": "Note: For EKS/GKE/AKS, ensure your local CLI (aws/gcloud/az) is authenticated.",
  "servers": {
    "k8s-helm-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "k8s-helm-mcp"
      ],
      "env": {
        "KUBECONFIG": "C:\\Users\\yourname\\.kube\\config",
        "STRICT_PROTECTION_MODE": "true"
      }
    }
  }
}
