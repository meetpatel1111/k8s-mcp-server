{
  "//": "Antigravity Configuration. Path: %USERPROFILE%\\.gemini\\antigravity\\mcp_config.json",
  "//-": "NOTE: For EKS/GKE/AKS, ensure aws-cli, gcloud, or az is installed for auth.",
  "mcpServers": {
    "k8s-helm-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "k8s-helm-mcp"],
      "env": {
        "KUBECONFIG": "C:\\path\\to\\your\\.kube\\config"
      }
    }
  }
}
