{
  "name": "k8s-helm-mcp",
  "version": "0.20.1",
  "description": "Production-grade Kubernetes MCP Server - Complete kubectl coverage with Infrastructure Protection, Helm support, Diagnostics, Response Caching, 260+ tools, Direct Exec, OpenTelemetry",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "k8s-helm-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && esbuild dist/index.js --bundle --platform=node --target=node18 --outfile=dist/index.bundle.js --minify --tree-shaking=true --format=esm --external:@modelcontextprotocol/sdk --external:@kubernetes/client-node --external:@opentelemetry/api --external:@opentelemetry/exporter-trace-otlp-grpc --external:@opentelemetry/instrumentation --external:@opentelemetry/resources --external:@opentelemetry/sdk-node --external:@opentelemetry/sdk-trace-node --external:@opentelemetry/semantic-conventions --external:js-yaml --external:zod --external:express && node -e \"const fs=require('fs'); const content=fs.readFileSync('dist/index.bundle.js', 'utf8'); fs.writeFileSync('dist/index.js', '#!/usr/bin/env node\\n' + content);\"",
    "build:dev": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:secure": "node --max-old-space-size=256 --experimental-permission --allow-fs-read=* --allow-child-process dist/index.js",
    "start:bun": "bun dist/index.js",
    "prepare": "husky install && npm run build",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "generate-docs": "node --loader ts-node/esm scripts/generate-api-docs.ts"
  },
  "keywords": [
    "kubernetes",
    "mcp",
    "kubectl",
    "kubelet",
    "k8s",
    "cluster-management",
    "devops",
    "helm",
    "diagnostics",
    "model-context-protocol"
  ],
  "author": "Meetkumar Patel <pmeet464@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meetpatel1111/k8s-helm-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.45.1",
    "@opentelemetry/instrumentation": "^0.45.1",
    "@opentelemetry/resources": "^1.18.1",
    "@opentelemetry/sdk-node": "^0.45.1",
    "@opentelemetry/sdk-trace-node": "^1.18.1",
    "@opentelemetry/semantic-conventions": "^1.18.1",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.50.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
